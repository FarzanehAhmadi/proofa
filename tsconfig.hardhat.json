{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["hardhat/types", "@nomicfoundation/hardhat-ethers/types"]
  },
  "include": [
    "hardhat.config.ts",
    "contracts/**/*",
    "scripts/**/*",
    "test/**/*"
  ],
  "exclude": ["node_modules"]
}
